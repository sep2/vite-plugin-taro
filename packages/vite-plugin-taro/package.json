{
    "name": "vite-plugin-taro",
    "version": "0.3.2",
    "author": "sep2",
    "description": "Vite 8 plugin for building one React/Taro codebase for WeChat Mini Program and H5 targets.",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sep2/vite-plugin-taro.git",
        "directory": "packages/vite-plugin-taro"
    },
    "bugs": {
        "url": "https://github.com/sep2/vite-plugin-taro/issues"
    },
    "homepage": "https://github.com/sep2/vite-plugin-taro/tree/main/packages/vite-plugin-taro#readme",
    "main": "./dist/vite.js",
    "module": "./dist/vite.js",
    "types": "./dist/vite.d.ts",
    "exports": {
        ".": {
            "types": "./dist/vite.d.ts",
            "import": "./dist/vite.js",
            "default": "./dist/vite.js"
        },
        "./client": {
            "types": "./client.d.ts"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "src",
        "client.d.ts",
        "LICENSE",
        "README.md",
        "README.zh.md"
    ],
    "scripts": {
        "build": "node ../../scripts/sync-plugin-readme.ts && node ../../scripts/clean-directory.ts dist && tsc --project tsconfig.build.json",
        "test": "node --test",
        "typecheck": "tsc --project tsconfig.json --noEmit"
    },
    "keywords": [
        "vite",
        "vite-plugin",
        "taro",
        "wechat",
        "mini-program",
        "react"
    ],
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": "^22.18.0 || >=24.11.0"
    },
    "dependencies": {
        "@babel/core": "^8.0.1",
        "@babel/generator": "^8.0.0",
        "@babel/plugin-transform-dynamic-import": "^8.0.1",
        "@babel/plugin-transform-modules-commonjs": "^8.0.1",
        "@babel/plugin-transform-modules-systemjs": "^8.0.1",
        "@rolldown/plugin-babel": "^0.2.3",
        "@tailwindcss-mangle/engine": "0.1.3",
        "@tarojs/components": "^4.2.0",
        "@tarojs/helper": "^4.2.0",
        "@tarojs/plugin-framework-react": "workspace:vite-plugin-taro-plugin-framework-react@*",
        "@tarojs/plugin-platform-h5": "^4.2.0",
        "@tarojs/plugin-platform-weapp": "^4.2.0",
        "@tarojs/react": "workspace:vite-plugin-taro-react@*",
        "@tarojs/router": "^4.2.0",
        "@tarojs/runtime": "^4.2.0",
        "@tarojs/taro": "^4.2.0",
        "@vitejs/plugin-react": "^6.0.3",
        "babel-plugin-transform-taroapi": "^4.2.0",
        "picocolors": "^1.1.1",
        "react-refresh": "^0.18.0",
        "rolldown": "~1.1.4",
        "rxjs": "^7.8.2",
        "systemjs": "6.15.1",
        "tailwindcss": "^4.3.2",
        "weapp-tailwindcss": "^5.1.16"
    },
    "peerDependencies": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "vite": "^8.1.4"
    },
    "devDependencies": {
        "@types/node": "^26.1.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/react-refresh": "^0.14.7",
        "typescript": "^7.0.2",
        "vite": "^8.1.4"
    }
}
