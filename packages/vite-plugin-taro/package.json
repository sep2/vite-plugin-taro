{
    "name": "vite-plugin-taro",
    "version": "0.0.6",
    "description": "Vite 8 plugin for building one React/Taro codebase for WeChat Mini Program and H5 targets.",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sep2/vite-plugin-taro.git",
        "directory": "packages/vite-plugin-taro"
    },
    "bugs": {
        "url": "https://github.com/sep2/vite-plugin-taro/issues"
    },
    "homepage": "https://github.com/sep2/vite-plugin-taro/tree/main/packages/vite-plugin-taro#readme",
    "main": "./dist/vite.js",
    "module": "./dist/vite.js",
    "exports": {
        ".": {
            "types": "./src/vite.ts",
            "import": "./dist/vite.js",
            "default": "./dist/vite.js"
        },
        "./client": {
            "types": "./client.d.ts"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "src",
        "client.d.ts",
        "LICENSE",
        "README.md"
    ],
    "scripts": {
        "build": "node ../../scripts/sync-plugin-readme.mjs && rm -rf dist && tsgo --project tsconfig.json",
        "typecheck": "tsgo --project tsconfig.json --noEmit"
    },
    "keywords": [
        "vite",
        "vite-plugin",
        "taro",
        "wechat",
        "mini-program",
        "react"
    ],
    "author": "felix",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=22"
    },
    "dependencies": {
        "@babel/core": "^7.29.7",
        "@rolldown/plugin-babel": "^0.2.3",
        "@tailwindcss/vite": "^4.3.1",
        "@tarojs/components": "^4.2.0",
        "@tarojs/helper": "^4.2.0",
        "@tarojs/plugin-framework-react": "workspace:vite-plugin-taro-plugin-framework-react@*",
        "@tarojs/plugin-platform-h5": "^4.2.0",
        "@tarojs/plugin-platform-weapp": "^4.2.0",
        "@tarojs/react": "workspace:vite-plugin-taro-react@*",
        "@tarojs/router": "^4.2.0",
        "@tarojs/runtime": "^4.2.0",
        "@tarojs/taro": "^4.2.0",
        "@vitejs/plugin-react": "^6.0.2",
        "babel-plugin-transform-taroapi": "^4.2.0",
        "tailwindcss": "^4.3.1",
        "weapp-tailwindcss": "^5.0.13"
    },
    "peerDependencies": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "vite": "^8.0.0"
    },
    "devDependencies": {
        "@types/babel__core": "^7.20.5",
        "@types/node": "^26.0.0",
        "@typescript/native-preview": "latest",
        "vite": "^8.0.16"
    }
}
