{
    "name": "vite-plugin-taro-monorepo",
    "version": "0.0.3",
    "private": true,
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sep2/vite-plugin-taro.git"
    },
    "bugs": {
        "url": "https://github.com/sep2/vite-plugin-taro/issues"
    },
    "homepage": "https://github.com/sep2/vite-plugin-taro#readme",
    "scripts": {
        "prepare:taro": "node scripts/build-patched-taro-packages.mjs",
        "build": "pnpm --filter vite-plugin-taro build",
        "build:plugin": "pnpm --filter vite-plugin-taro build",
        "build:sample:h5": "pnpm --filter loan-genius build-h5",
        "build:sample:wx": "pnpm --filter loan-genius build-wx",
        "dev:sample:h5": "pnpm --filter loan-genius dev-h5",
        "dev:sample:wx": "pnpm --filter loan-genius dev-wx",
        "preview:sample:h5": "pnpm --filter loan-genius preview-h5",
        "typecheck": "pnpm --filter vite-plugin-taro typecheck && pnpm --filter loan-genius typecheck",
        "lint": "biome check .",
        "format": "biome check --write .",
        "pack:dry": "pnpm prepare:taro && pnpm --filter vite-plugin-taro-react pack --dry-run && pnpm --filter vite-plugin-taro-plugin-framework-react pack --dry-run && pnpm --filter vite-plugin-taro pack:dry",
        "publish:all": "node scripts/publish-packages.mjs",
        "publish:dry": "node scripts/publish-packages.mjs --dry-run"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.0",
        "@typescript/native-preview": "latest"
    },
    "packageManager": "pnpm@11.6.0"
}
